# Discord Application (Client) ID — required for the Embedded App SDK.
# Found at https://discord.com/developers/applications under your app's
# "General Information" → "Application ID".
VITE_DISCORD_CLIENT_ID=your_discord_application_id_here

# Server-side options (optional)
DEMO_MODE=true
HERMES_GATEWAY_URL=ws://host.docker.internal:18789/
