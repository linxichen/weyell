# Discord Application (Client) ID — required for the Embedded App SDK.
# Found at https://discord.com/developers/applications under your app's
# "General Information" → "Application ID".
VITE_DISCORD_CLIENT_ID=your_discord_application_id_here

# Discord Bot Token — used by the WeYell server to read agent status
# messages from the office channel via Discord REST API.
# Create at https://discord.com/developers/applications → Bot → Reset Token
DISCORD_BOT_TOKEN=your_bot_token_here

# Discord channel ID where Hermes posts agent status embeds.
# Right-click the channel in Discord → Copy Channel ID (needs Developer Mode on)
DISCORD_CHANNEL_ID=your_channel_id_here

# Set to false to use live Discord feed instead of demo mode
DEMO_MODE=true
